# === LLM Providers ===
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Provider to use: "groq" or "ollama"
LLM_PROVIDER=groq

# === Database ===
DATABASE_PATH=./data/alice.db

# === Persona ===
PERSONA_PATH=./alice/persona.yaml

# === Memory ===
MAX_HISTORY_MESSAGES=20

# === Voice / Audio (Phase 3+) ===
# WAKE_WORD_MODEL=hey_jarvis          # or path to custom .onnx model
# WAKE_WORD_THRESHOLD=0.5             # 0.0-1.0, lower = more sensitive
# STT_MODEL_SIZE=base.en              # tiny.en / base.en / small / medium
# SPEAKER_VERIFY_THRESHOLD=0.35

# === Weather (Phase 2+) ===
# OPENWEATHER_API_KEY=your_openweathermap_key_here
# WEATHER_CITY=Manila
# WEATHER_COUNTRY_CODE=PH

# === Music (Phase 7) ===
# SHOOT_TO_THRILL_PATH=C:/Music/AC_DC-Shoot_To_Thrill.mp3

# === Preset Apps (Phase 7) ===
# PRESET_APPS=chrome,spotify,discord

# === Language (Phase 8) ===
# DEFAULT_LANGUAGE=en                  # "en" or "ja" — starting language
# STT_MODEL_SIZE_JA=small             # multilingual Whisper model for Japanese STT
#   Note: For Japanese voice input, also set STT_MODEL_SIZE=small
#         Japanese text chat works without changing the STT model.

# === Owner PIN (virtual auth when mic unavailable) ===
# Typing this in chat triggers the full boot sequence (same as double clap)
OWNER_PIN=120901

# === Logging ===
LOG_LEVEL=INFO
